# Nombre de la aplicación
SPRING_APPLICATION_NAME=spring-security-labo

CORS_ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL (Docker Compose + local)
POSTGRES_DB=spring_security_labo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Configuración de la base de datos PostgreSQL
# Local: localhost | Docker Compose: jdbc:postgresql://db:5432/${POSTGRES_DB}
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/spring_security_labo
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Configuración de JPA / Hibernate
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_DATA_WEB_PAGEABLE_ONE_INDEXED_PARAMETERS=false

# Puerto del servidor
SERVER_PORT=4000

# Configuración de seguridad JWT
SECURITY_JWT_SECRET_KEY=c3ByaW5nLXNlY3VyaXR5LWxhYm8tand0LXNlY3JldC1rZXktMzJiIQ==
SECURITY_JWT_EXPIRATION_TIME=3600000
